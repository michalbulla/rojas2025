

  {% if side == 'left' %}
    {% set nav = siteOptions.mainNavigation|slice(0,4) %}
  {% elseif side == 'right' %}
    {% set nav = siteOptions.mainNavigation|slice(4,8) %}
  {% else %}
    {% set nav = siteOptions.mainNavigation %}
  {% endif %}

  {% apply spaceless %}
    <nav class="absolute left-0 top-[87px] z-10 hidden w-full bg-brand-one lg:bg-transparent lg:w-auto lg:static lg:block lg:-mt-16" id="main-nav" role="menu" tabindex="-1">
      <ul class="list-none">
        {% for entry in nav %}
          <li class="lg:relative lg:inline-block group">
            <div class="flex justify-between items-center px-2 lg:px-0">
              <a class="flex-grow block lg:mx-2 lg-xl:mx-4 py-3 lg:py-2 font-navigation uppercase text-white transition-colors duration-300 ease-linear lg:border-b-2 lg:border-transparent lg:hover:border-brand-two lg:focus:border-brand-two lg:inline-block lg:text-[23px] lg-xl:text-2xl" role="menuitem" href="{{ entry.url }}">
                {{ entry.title }}
              </a>
              {% if entry.getChildren|length %}
                <button type="button" aria-label="Main Navigation Subpages Toggle" title="Main Navigation Subpages Toggle" aria-expanded="false" aria-controls="main-navigation-subpages" _="on click toggle .hidden on the <div/> in me then toggle .hidden on the next <ul/>">
                  <div class="main-nav-chevron block px-4 lg:hidden text-white">
                    {{ svg("@webroot/img/icons/chevron-right-solid.svg")|attr({class: 'h-5 w-5 inline-block'}) }}
                  </div>
                  <div class="main-nav-chevron hidden px-4 lg:hidden text-white">
                    {{ svg("@webroot/img/icons/chevron-down-solid.svg")|attr({class: 'h-5 w-5 inline-block'}) }}
                  </div>
                </button>
              {% endif %}
            </div>
            {% set childPages = entry.getChildren().all %}
            {% if childPages | length %}
              <ul id="main-navigation-subpages" class="z-20 lg:absolute hidden w-full lg:w-80 divide-y divide-gray-500 shadow-lg lg:group-hover:block bg-white/95 top-[50px] left-4">
                {% for page in childPages %}
                  <li>
                    <a class="block px-3 py-3 text-gray-600 normal-case hover:bg-brand-one/70 hover:text-white text-lg" href="{{ page.url() }}">{{ page.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  {% endapply %}

